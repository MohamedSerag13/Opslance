# /etc/sudoers.d/lab-student
# Managed by Opslance lab-manager — DO NOT EDIT MANUALLY
#
# Grants the 'intern' user passwordless sudo for a safe whitelist of commands.
# All other commands are implicitly denied because this file does NOT grant
# full sudo and the base sudoers has no wildcard rule for 'intern'.

# Suppress "unable to resolve host" warning — containers have no DNS for their
# own hostname (network_mode: none). The fqdn option causes sudo to call
# getaddrinfo() to resolve the hostname into a FQDN; disabling it prevents
# the warning entirely without needing any /etc/hosts changes.
Defaults !fqdn

# ── Full passwordless sudo access ─────────────────────────────────────────────
intern ALL=(ALL) NOPASSWD: ALL

# ── Security note ─────────────────────────────────────────────────────────────
# The 'intern' user is granted full passwordless sudo privileges for all commands
# to enable unrestricted learning and exploration across all labs.

