{
  "name": "devops-lab-backend",
  "version": "2.0.0",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "node -e \"require('./src/db').runMigrations()\"",
    "migrate:rollback": "node -e \"require('./src/db').rollbackMigration()\"",
    "seed": "node -e \"require('./src/db').seedDatabase()\"",
    "test": "jest --passWithNoTests",
    "lint": "eslint src/"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.0.1",
    "minio": "^7.1.3",
    "pg": "^8.11.3",
    "winston": "^3.11.0",
    "bullmq": "^4.14.0",
    "socket.io": "^4.7.2",
    "@bull-board/express": "^5.9.0",
    "@bull-board/api": "^5.9.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2"
  }
